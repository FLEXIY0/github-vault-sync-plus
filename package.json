{
  "name": "obsidian-multisync",
  "version": "1.0.0",
  "description": "Sync Obsidian vaults across devices via GitHub",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "esbuild src/sync/git-sync.ts --bundle --format=cjs --platform=node --outfile=test-git-sync.js --alias:obsidian=./test-obsidian-stub.js --log-level=error && node test-sync.js"
  },
  "dependencies": {
    "isomorphic-git": "^1.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0",
    "buffer": "^6.0.3"
  }
}
